# Analytics & Search Console
# All optional — if unset, no scripts or meta tags are emitted.

# Google Analytics 4 measurement ID (looks like: G-XXXXXXXXXX)
# Get from: https://analytics.google.com/ → Admin → Data Streams → Web → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification code (the value of the meta tag, not the full tag)
# Get from: https://search.google.com/search-console/ → Add property (URL prefix) → HTML tag
# Example value: abc123XYZ...
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools verification code (optional — Bing/Yahoo traffic only)
# Get from: https://www.bing.com/webmasters/ → Add a site → Meta tag option
NEXT_PUBLIC_BING_VERIFICATION=
